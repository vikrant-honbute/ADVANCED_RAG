   "source": [
    "import os\n",
    "from typing import List, Annotated\n",
    "from pydantic import BaseModel, Field\n",
    "\n",
    "from langhchain_community.vectorstores import FAISS\n",
    "from langchain_community.document_loaders import WebBaseLoader\n",
    "from lamghchain_text_splitters import RecursiveCharacterTextSplitter\n",
    "from langchain.chat_models import init_chat_model\n",
    "from langchain_openai import OpenAIEmbeddings\n",
    "from langchain.schema import Document\n",
    "from langgraph.graph import StarGraph, END\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bfa90925",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "from dotenv import load_dotenv\n",
    "load_dotenv()\n",
    "os.environ[\"OPENAI_API_KEY\"] = os.getenv(\"OPENAI_API_KEY\")\n",
    "llm = init_chat_model(\"gpt-3.5-turbo\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2d337ee5",
   "metadata": {},
   "outputs": [],
   "source": [
    "## DOC PREPROCESSING\n",
    "urls = [\n",
    "    \"https://en.wikipedia.org/wiki/Artificial_intelligence\",\n",
    "    \"https://en.wikipedia.org/wiki/Machine_learning\",\n",
    "]\n",
    "\n",
    "loader = [WebBaseLoader(url) for url in urls]\n",
    "docs = []\n",
    "for loader in loaders:\n",
    "    docs.extend(loader.load())\n",
    "\n",
    "docs"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "dbafdf0b",
   "metadata": {},
   "outputs": [],
   "source": [
    "## RecurviceeCharacterTextSplitter\n",
    "text_splitter = RecursiveCharacterTextSplitter(chunk_size=1000, chunk_overlap=200)\n",
    "split_docs = text_splitter.split_documents(docs)\n",
    "\n",
    "embeddings = OpenAIEmbeddings(model=\"text-embedding-3-small\")\n",
    "vectorstore = FAISS.from_documents(split_docs, embeddings)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7a4336e6",
   "metadata": {},
   "outputs": [],
   "source": [
    "## Define the graph schema\n",
    "\n",
    "class RAGGraph(StarGraph):\n",
    "    questions: str\n",
    "    retrieved_docs: List[Document]\n",
    "    answer: str = \"\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "009f749e",
   "metadata": {},
   "outputs": [],
   "source": [
    "#3 Langgraph nodes\n",
    "\n",
    "def retrieve_docs(graph: RAGGraph) -> RAGGraph:\n",
    "    docs = retriver.invoke(state.question)\n",
    "    return RAGGraph(\n",
    "        questions=graph.questions,\n",
    "        retrieved_docs=docs,\n",
    "    )\n",
    "\n",
    "def generate_answer(graph: RAGGraph) -> RAGGraph:\n",
    "    context = \"\\n\".join([doc.page_content for doc in graph.retrieved_docs])\n",
    "    prompt = f\"Answer the question based on the following context:\\n\\nContext: {context}\\n\\nQuestion: {graph.questions}\"\n",
    "    response = llm.invoke(prompt)\n",
    "    return RAGGraph(\n",
    "        questions=graph.questions,\n",
    "        retrieved_docs=graph.retrieved_docs,\n",
    "        answer=response,\n",
    "    )"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "afaac6dc",
   "metadata": {},
   ,
   "source": [
    "## build the graph\n",
    "builder = StateGraph(RAGGraph)\n",
    "\n",
    "builder.add_node(\"retrever\", retrieve_docs)\n",
    "builder.add_node(\"generator\", generate_answer)\n",
    "\n",
    "\n",
    "builder.set_entry_point(\"retriever\")\n",
    "builder.add_edge(\"retriever\", \"generator\")\n",
    "builder.add_edges(\"generator\", END)\n",
    "\n",
    "\n",
    "graph = builder.compile()\n",
    "graph"
   ]
  }
